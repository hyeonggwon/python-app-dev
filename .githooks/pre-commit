#!/usr/bin/env bash
# Cross-file invariant checker + harness self-tests — must pass before any
# commit lands. Bypassing this hook (`--no-verify`) is forbidden by CLAUDE.md.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
python3 "$ROOT/scripts/validate_harness.py"
python3 -m pytest "$ROOT/scripts/tests/" -q
